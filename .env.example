# Local environment variables for TestPilot Lite RAG

# LLM provider selection: mock, openai, azure_openai, ollama, foundry_local
LLM_PROVIDER=mock

# OpenAI credentials
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Azure OpenAI credentials
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_MODEL=gpt-4o-mini

# Ollama settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Database / storage
DATABASE_URL=sqlite:///./backend/backend.db
